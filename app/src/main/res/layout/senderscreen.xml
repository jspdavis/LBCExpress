<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#E31A2D"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="LBC"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:text="1  Sender Information    2  3  4"
                android:textColor="#111827"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sender Details"
                        android:textColor="#111827"
                        android:textStyle="bold" />

                    <TextView style="@style/LabelStyle" android:text="First Name *" />
                    <EditText android:id="@+id/etFirstName" style="@style/InputBoxStyle" />

                    <TextView style="@style/LabelStyle" android:text="Last Name *" />
                    <EditText android:id="@+id/etLastName" style="@style/InputBoxStyle" />

                    <TextView style="@style/LabelStyle" android:text="Phone Number *" />
                    <EditText
                        android:id="@+id/etMobile"
                        style="@style/InputBoxStyle"
                        android:hint="9XX XXX XXXX"
                        android:inputType="phone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Drop Off Area"
                        android:textStyle="bold" />

                    <TextView style="@style/LabelStyle" android:text="Province *" />
                    <Spinner android:id="@+id/spProvince" style="@style/InputBoxStyle" android:background="@drawable/spinner_bg" />

                    <TextView style="@style/LabelStyle" android:text="City/Municipality *" />
                    <Spinner android:id="@+id/spCity" style="@style/InputBoxStyle" android:background="@drawable/spinner_bg" />

                    <TextView style="@style/LabelStyle" android:text="Drop Off Branch *" />
                    <Spinner android:id="@+id/spDropBranch" style="@style/InputBoxStyle" android:background="@drawable/spinner_bg" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:backgroundTint="#E31A2D"
        android:text="Next"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:cornerRadius="8dp" />

</LinearLayout>